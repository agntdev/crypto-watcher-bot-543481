[
  {
    "name": "empty watchlist shows message",
    "steps": [
      {
        "send": { "callback": "price:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Your watchlist is empty — tap 🪙 Watchlist to add some coins." }
          }
        ]
      }
    ]
  },
  {
    "name": "/price with empty watchlist",
    "steps": [
      {
        "send": { "text": "/price" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Your watchlist is empty — tap 🪙 Watchlist to add some coins." }
          }
        ]
      }
    ]
  }
]
